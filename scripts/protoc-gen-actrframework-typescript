#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Prefer bundle.js (single-file build), fallback to main.js (dev build)
if [[ -f "$PROJECT_DIR/dist/bundle.js" ]]; then
  ENTRY="$PROJECT_DIR/dist/bundle.js"
elif [[ -f "$PROJECT_DIR/dist/main.js" ]]; then
  ENTRY="$PROJECT_DIR/dist/main.js"
else
  echo "Neither dist/bundle.js nor dist/main.js found. Run 'npm install && npm run bundle' or 'npm run build' in $PROJECT_DIR" >&2
  exit 1
fi

exec node "$ENTRY" "$@"
