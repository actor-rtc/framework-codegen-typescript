{
  "name": "framework-codegen-typescript",
  "version": "0.1.10",
  "private": true,
  "description": "TypeScript protoc plugin for Actor-RTC framework",
  "bin": {
    "protoc-gen-actrframework-typescript": "scripts/protoc-gen-actrframework-typescript"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/main.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "esbuild": "^0.27.3",
    "typescript": "^5.6.3"
  }
}